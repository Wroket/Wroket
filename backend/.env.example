PORT=3001
COOKIE_SECURE=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/calendar/google/callback
GOOGLE_SSO_REDIRECT_URI=http://localhost:3001/auth/google/callback
FRONTEND_URL=http://localhost:3000
# Set to "true" to use local JSON file instead of Firestore
USE_LOCAL_STORE=true

# AES-256 key (base64, 32 bytes) to wrap per-user data keys. Required to encrypt todo titles/tags
# and task comments at rest. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Store in Secret Manager in production; loss of this key makes encrypted user content unrecoverable.
CRYPTO_KEK_BASE64=

# Admin emails (comma-separated)
ADMIN_EMAILS=francois@broudeur.com

# SMTP for email verification (leave empty to disable emails in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Visible "From" address on all transactional emails (invites, verify, reset).
# If unset, the code falls back to SMTP_USER — so a personal Gmail shows as sender.
# Use an address your SMTP provider allows (e.g. team@wroket.com with Workspace "send as" or a relay).
EMAIL_FROM=team@wroket.com
