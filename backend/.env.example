PORT=3001
COOKIE_SECURE=false
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3002
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/calendar/google/callback
GOOGLE_SSO_REDIRECT_URI=http://localhost:3001/auth/google/callback
# Microsoft Entra ID — SSO + Outlook (optional in dev) — voir docs/microsoft-azure.md
# Directory tenant ID : 4d7ec8e5-e09d-439d-8954-0f90454b1b28
# Application (client) ID prod : e75f60be-547f-40fe-b910-5feb59a600bc
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
# OAuth authority: "common" = multi-tenant + comptes perso (prod SaaS). Directory ID uniquement si single-tenant.
MICROSOFT_TENANT_ID=common
MICROSOFT_SSO_REDIRECT_URI=http://localhost:3001/auth/microsoft/callback
# Outlook / Graph (calendar) — separate OAuth redirect from SSO
MICROSOFT_GRAPH_REDIRECT_URI=http://localhost:3001/calendar/microsoft/callback
FRONTEND_URL=http://localhost:3000
# Optional: e.g. .wroket.com — makes auth_token visible on both wroket.com (Next middleware) and api.wroket.com. If unset, derived from FRONTEND_URL in production.
# COOKIE_DOMAIN=
# HMAC for OAuth state (Calendar + Google / Microsoft SSO + Notion). Required when NODE_ENV=production (e.g. Cloud Run).
# Recommended in local dev too: without it, each API restart generates a new key and SSO callbacks fail after a restart mid-flow.
OAUTH_STATE_SECRET=

# Notion public OAuth (Small teams+ integrations). Redirect must match Notion integration settings.
# Prod: https://api.wroket.com/integrations/notion/callback
# NOTION_CLIENT_ID=
# NOTION_CLIENT_SECRET=
# NOTION_REDIRECT_URI=http://localhost:3001/integrations/notion/callback

# Monday.com OAuth (Small teams+ integrations). Redirect must match Monday app settings.
# In Monday Dev Center → OAuth & Permissions: enable scopes boards:read + docs:read (exact match with MONDAY_OAUTH_SCOPES).
# MONDAY_OAUTH_SCOPES=boards:read docs:read
MONDAY_OAUTH_SCOPES=boards:read docs:read
# Prod: https://api.wroket.com/integrations/monday/callback
# MONDAY_CLIENT_ID=
# MONDAY_CLIENT_SECRET=
# MONDAY_REDIRECT_URI=http://localhost:3001/integrations/monday/callback

# Set to "true" to use local JSON file instead of Firestore
USE_LOCAL_STORE=true

# Optional: only for one-off migration `npm run migrate:strip-encryption` if legacy encrypted rows exist.
# Same 32-byte key (base64) that was used when content was encrypted; not used by the running API.
CRYPTO_KEK_BASE64=

# Admin emails (comma-separated)
ADMIN_EMAILS=francois@broudeur.com,team@wroket.com

# Admin ops email alerts (prod only, requires SMTP). Cooldown per alert type in minutes.
# ADMIN_OPS_ALERTS_ENABLED=false
# ADMIN_OPS_ALERT_COOLDOWN_MINUTES=60
# ADMIN_OPS_ALERT_CHECK_MINUTES=15
# ADMIN_OPS_ALERT_TO=ops@example.com
# ADMIN_OPS_FLUSH_STALE_MINUTES=10

# SMTP for email verification (leave empty to disable emails in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Visible "From" address on all transactional emails (invites, verify, reset).
# If unset, the code falls back to SMTP_USER — so a personal Gmail shows as sender.
# Use an address your SMTP provider allows (e.g. team@wroket.com with Workspace "send as" or a relay).
EMAIL_FROM=team@wroket.com

# Stripe — billing plan + customer/subscription fields (`POST /billing/stripe-webhook`, raw body).
# Authenticated users: `POST /billing/create-portal-session` (JSON) opens the Stripe Customer Portal
# (enable “Customer portal” in the Stripe Dashboard for this account).
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# Web Push (VAPID) — background notifications via PWA service worker.
# Generate keys: npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https: URL (contact for push service).
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:team@wroket.com
